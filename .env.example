# ── App ───────────────────────────────────────────────
APP_NAME=Customer Monitoring System
DEBUG=false
SECRET_KEY=change-me-in-production

# ── CORS ──────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── Database ──────────────────────────────────────────
# Local dev (SQLite)
DATABASE_URL=sqlite:///./customer_monitoring.db
# Production (PostgreSQL)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/customer_monitoring

# ── ML Model Artifacts ────────────────────────────────
MODEL_DIR=models/artifacts
CHURN_MODEL_PATH=models/artifacts/churn_xgb.joblib
SEGMENT_MODEL_PATH=models/artifacts/segment_xgb.joblib
ANOMALY_MODEL_PATH=models/artifacts/anomaly_iso.joblib
SCALER_PATH=models/artifacts/feature_scaler.joblib
ENCODER_PATH=models/artifacts/label_encoder.joblib

# ── NLP Model ─────────────────────────────────────────
SENTIMENT_MODEL=cardiffnlp/twitter-roberta-base-sentiment-latest

# ── XGBoost Hyperparameters ───────────────────────────
XGB_N_ESTIMATORS=300
XGB_MAX_DEPTH=6
XGB_LEARNING_RATE=0.05
XGB_SUBSAMPLE=0.8
XGB_COLSAMPLE_BYTREE=0.8
XGB_USE_GPU=false

# ── Thresholds ────────────────────────────────────────
CHURN_THRESHOLD=0.5
ANOMALY_CONTAMINATION=0.05

# ── MLOps (optional) ──────────────────────────────────
# MLFLOW_TRACKING_URI=http://localhost:5000
EXPERIMENT_NAME=customer-monitoring
ENABLE_DATA_DRIFT=true

# ── Cloud Storage (optional) ──────────────────────────
MODEL_STORAGE_BACKEND=local
# AWS_S3_BUCKET=your-bucket-name
# GCS_BUCKET=your-gcs-bucket
